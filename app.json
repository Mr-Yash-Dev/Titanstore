{
  "name": "TG File Store/Sharing Bot",
  "description": "File sharing bot to store posts and access them via special links.",
  "keywords": ["telegram", "file", "sharing", "bot"],
  "repository": "https://github.com/Mr-Yash-Dev/Titan-FileStore",
  "env": {
    "TG_BOT_TOKEN": { "description": "Your Bot token from @Botfather.", "required": true },
    "APP_ID": { "description": "Your APP ID from my.telegram.org.", "required": true },
    "API_HASH": { "description": "Your API HASH from my.telegram.org.", "required": true },
    "OWNER_ID": { "description": "Your owner Telegram numeric ID.", "required": true },
    "ADMINS": { "description": "Space separated list of admin IDs.", "required": false },
    "DATABASE_URL": { "description": "Your MongoDB connection URL.", "required": true },
    "DATABASE_NAME": { "description": "MongoDB Database Name.", "value": "filesharexbot", "required": true },
    "CHANNEL_ID": { "description": "Database channel ID (Include -100).", "required": true },
    "LOG_CHANNEL_ID": { "description": "Log channel ID for bot updates.", "required": true },
    "PORT": { "value": "8080", "required": false }
  }
}
